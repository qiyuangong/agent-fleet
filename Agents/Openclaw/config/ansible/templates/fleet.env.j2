# Per-node fleet configuration rendered by Ansible
COUNT={{ count | default(3) }}
BASE_URL={{ base_url }}
API_KEY={{ api_key }}
MODEL={{ model }}
OPENCLAW_IMAGE={{ openclaw_image }}
CONFIG_BASE={{ config_base | default('$HOME/openclaw-instances') }}
WORKSPACE_BASE={{ workspace_base | default('$HOME/openclaw-workspaces') }}
{% if npm_config_registry is defined and npm_config_registry %}
NPM_CONFIG_REGISTRY={{ npm_config_registry | default('') }}
{% endif %}
{% if pip_index_url is defined and pip_index_url %}
PIP_INDEX_URL={{ pip_index_url | default('') }}
{% endif %}
{% if pip_extra_index_url is defined and pip_extra_index_url %}
PIP_EXTRA_INDEX_URL={{ pip_extra_index_url | default('') }}
{% endif %}
{% if pip_trusted_host is defined and pip_trusted_host %}
PIP_TRUSTED_HOST={{ pip_trusted_host | default('') }}
{% endif %}
CPU_LIMIT={{ cpu_limit | default('2') }}
MEM_LIMIT={{ mem_limit | default('4G') }}
CONTAINER_NAME_PREFIX={{ container_name_prefix | default('openclaw') }}
PORT_STEP={{ port_step | default('20') }}
DEFAULT_PORTS_OFFSET={{ default_ports_offset | default('0') }}
SANDBOX_MODE={{ sandbox_mode | default('off') }}
HEARTBEAT_EVERY={{ heartbeat_every | default('0m') }}
EXEC_SECURITY={{ exec_security | default('deny') }}
EXEC_ASK={{ exec_ask | default('always') }}
DOCKER_COMPOSE_READ_ONLY={{ docker_compose_read_only | default('true') }}
TZ={{ tz | default('Asia/Shanghai') }}

# Opik tracer plugin (opt-in; requires image built with OPIK_PLUGIN=enabled)
{% if opik_plugin is defined and opik_plugin == 'enabled' %}
OPIK_PLUGIN=enabled
OPIK_URL={{ opik_url }}
OPIK_API_KEY={{ opik_api_key | default('') }}
OPIK_WORKSPACE={{ opik_workspace | default('default') }}
OPIK_PROJECT_NAME={{ opik_project_name }}
{% endif %}
