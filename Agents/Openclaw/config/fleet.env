# Claw-Fleet configuration
# Use this file for setup configuration.
#
# config/fleet.env  — setup configuration
# Values here override caller environment variables (setup.sh sources this
# file after the caller's env). CLI flags override both.

# Model provider
# BASE_URL=https://api.example.com/v1
# API_KEY=sk-xxx
# MODEL_ID=nex/nex-n1.1

# Fleet size (can also be passed as argument: ./scripts/setup.sh 5)
# COUNT=3

# Directories
# CONFIG_BASE=$HOME/openclaw-instances
# WORKSPACE_BASE=$HOME/openclaw-workspaces
# OPENCLAW_CONFIG_CHMOD=a+rwX
# OPENCLAW_CONFIG_DEFAULT_ACL=true
# OPENCLAW_WORKSPACE_CHMOD=a+rwX
# OPENCLAW_WORKSPACE_DEFAULT_ACL=true

# Package mirrors passed into generated containers
# NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_EXTRA_INDEX_URL=
# PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Resource limits per container
# CPU_LIMIT=2
# MEM_LIMIT=4G

# Service/container naming
# CONTAINER_NAME_PREFIX=openclaw

# Port gap between instances (default: 20, per gateway docs)
# PORT_STEP=20

# Add this offset to the base host gateway port 18789
# DEFAULT_PORTS_OFFSET=0

# Generated OpenClaw config defaults
# SANDBOX_MODE=off
# HEARTBEAT_EVERY=0m
# EXEC_SECURITY=deny
# EXEC_ASK=always

# Generated docker-compose security defaults
# DOCKER_COMPOSE_READ_ONLY=true

# Docker image
# OPENCLAW_IMAGE=openclaw:local

# Timezone
# TZ=Asia/Shanghai

# Opik tracing plugin (opt-in; requires image built with OPIK_PLUGIN=enabled)
# OPIK_PLUGIN=enabled
# OPIK_URL=
# OPIK_API_KEY=
# OPIK_WORKSPACE=default
# OPIK_PROJECT_NAME=
