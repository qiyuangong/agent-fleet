+function hasConfiguredHttpBaseUrl(baseUrl?: string): boolean {
+  const trimmed = baseUrl?.trim();
+  if (!trimmed) {
+    return false;
+  }
+  try {
+    const protocol = new URL(trimmed).protocol;
+    return protocol === "http:" || protocol === "https:";
+  } catch {
+    return false;
+  }
+}
+
+export function usesOpenAICompatibleHttpRoute(provider: string, baseUrl?: string): boolean {
+  if (usesKnownNativeOpenAIRoute(provider, baseUrl)) {
+    return true;
+  }
+  const normalizedProvider = normalizeProviderId(provider);
+  if (
+    !normalizedProvider ||
+    normalizedProvider === "openai" ||
+    normalizedProvider === OPENAI_CODEX_PROVIDER_ID ||
+    AZURE_PROVIDER_IDS.has(normalizedProvider)
+  ) {
+    return false;
+  }
+  return hasConfiguredHttpBaseUrl(baseUrl);
+}
+
