# PinchBench runner configuration
# Edit this file for benchmark-specific defaults.
# Environment variables still override these values.

# Required in this file only if MODEL is not already set in repo-root config.env:
# MODEL=your-model-id
#
# Set this when auto-detection is not enough, especially for local OpenAI-compatible
# backends such as vLLM or SGLang. Optional for OpenRouter-backed fleets:
# PINCHBENCH_MODEL_PROVIDER=auto
#
# Optional judge override:
# JUDGE_MODEL=

# Optional checkout and output settings:
# PINCHBENCH_DIR=/tmp/pinchbench-skill
# PINCHBENCH_REF=f3f1cb560c252541cef6a106c05ba4f2e8068be0
# PINCHBENCH_OUTPUT_DIR=Tasks/Pinchbench/.pinchbench-results-docker

# Optional worker image and sync source:
# PINCHBENCH_DOCKER_IMAGE=pinchbench-runner:local
# Local relative paths are resolved from the agent-fleet repository root.
# PINCHBENCH_REPO_URL=https://github.com/pinchbench/skill

# Optional behavior flags:
# PINCHBENCH_FORCE_BUILD=false
# PINCHBENCH_UPLOAD=false
