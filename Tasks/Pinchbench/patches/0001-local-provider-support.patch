+def validate_model(model_id: str, timeout_seconds: float = 10.0) -> bool:
+    """
+    Validate a model ID when the active provider supports remote catalog checks.
+
+    For locally hosted OpenAI-compatible providers such as vLLM and SGLang,
+    PinchBench cannot verify the model against a central catalog, so validation
+    is skipped and OpenClaw is allowed to handle the real request path.
+    """
+    provider = detect_model_provider(model_id)
+    if provider == "openrouter":
+        return validate_openrouter_model(model_id, timeout_seconds=timeout_seconds)
+
+    logger.info(
+        "Skipping remote model validation for provider '%s': %s",
+        provider,
+        model_id,
+    )
+    return True
+
