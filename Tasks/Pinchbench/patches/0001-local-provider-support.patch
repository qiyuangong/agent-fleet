+def _normalize_model_provider(provider: str | None) -> str:
+    if not provider:
+        return "auto"
+    normalized = provider.strip().lower()
+    aliases = {
+        "auto": "auto",
+        "openrouter": "openrouter",
+        "local": "openai-compatible",
+        "openai": "openai-compatible",
+        "openai-compatible": "openai-compatible",
+        "vllm": "openai-compatible",
+        "sglang": "openai-compatible",
+    }
+    return aliases.get(normalized, normalized)
+
+
+def _openclaw_config_candidates() -> List[Path]:
+    candidates: List[Path] = []
+
+    config_path = os.environ.get("OPENCLAW_CONFIG_PATH")
+    if config_path:
+        candidates.append(Path(config_path).expanduser())
+
+    candidates.extend(
+        [
+            Path.home() / ".openclaw" / "openclaw.json",
+            Path.home() / "openclaw-instances" / "1" / "openclaw.json",
+        ]
+    )
+
+    deduped: List[Path] = []
+    seen = set()
+    for path in candidates:
+        key = str(path)
+        if key not in seen:
+            seen.add(key)
+            deduped.append(path)
+    return deduped
+
+
+def _load_default_provider_config() -> Dict[str, Any] | None:
+    for config_path in _openclaw_config_candidates():
+        if not config_path.exists():
+            continue
+        try:
+            payload = json.loads(config_path.read_text(encoding="utf-8"))
+        except (OSError, json.JSONDecodeError) as exc:
+            logger.warning("Failed to read OpenClaw config %s: %s", config_path, exc)
+            continue
+
+        provider = (
+            payload.get("models", {})
+            .get("providers", {})
+            .get("default", {})
+        )
+        if isinstance(provider, dict) and provider:
+            return provider
+    return None
+
+
+def detect_model_provider(model_id: str) -> str:
+    """
+    Detect the model provider backing the current OpenClaw config.
+
+    Returns one of:
+      - "openrouter"
+      - "openai-compatible"
+      - "unknown"
+    """
+    configured = _normalize_model_provider(os.environ.get("PINCHBENCH_MODEL_PROVIDER"))
+    if configured != "auto":
+        return configured
+
+    provider = _load_default_provider_config()
+    if not provider:
+        if "/" not in model_id:
+            return "unknown"
+        return "openrouter"
+
+    base_url = str(provider.get("baseUrl", "") or "").strip()
+    if not base_url:
+        return "unknown"
+
+    parsed = urlparse(base_url)
+    hostname = (parsed.hostname or "").lower()
+    if "openrouter.ai" in hostname:
+        return "openrouter"
+    if parsed.scheme in {"http", "https"}:
+        return "openai-compatible"
+    return "unknown"
+
+
