@@ -314,6 +314,23 @@ def _get_agent_workspace(agent_id: str) -> Path | None:
         return None
 
 
+def wait_for_agent_workspace(
+    agent_id: str,
+    workspace_dir: Path,
+    *,
+    timeout_seconds: float = 30.0,
+    poll_interval_seconds: float = 1.0,
+) -> bool:
+    target_workspace = workspace_dir.resolve()
+    deadline = time.time() + timeout_seconds
+    while time.time() <= deadline:
+        current_workspace = _get_agent_workspace(agent_id)
+        if current_workspace is not None and current_workspace.resolve() == target_workspace:
+            return True
+        time.sleep(poll_interval_seconds)
+    return False
+
+
